      "q": "When does school start for Prince William County Public Schools in 2026-2027?",
      "a": "The first day of school for Prince William County Public Schools is Monday, August 24, 2026. Students and staff are expected to report on this date to begin the new academic year."
    },
    {
      "q": "When is spring break 2026-2027 for Prince William County Public Schools?",
      "a": "Spring break for Prince William County Public Schools runs Mar 22, 2027–Mar 26, 2027, 5 days."
    },
    {
      "q": "When is winter break 2026-2027 for Prince William County Public Schools?",
      "a": "Winter break for Prince William County Public Schools runs Dec 21, 2026–Jan 1, 2027, 12 days. School resumes Jan 4, 2027."
    }
